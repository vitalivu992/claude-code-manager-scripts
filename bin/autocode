#!/usr/bin/env bash
set -euo pipefail

AUTOCODE_HOME="$(cd "$(dirname "$(realpath "${BASH_SOURCE[0]}")")/.." && pwd)"
SCRIPTS_DIR="$AUTOCODE_HOME/scripts"

source "$SCRIPTS_DIR/tmux-session.sh"
load_config

datadir="$HOME/.claude-auto-code"
mkdir -p "$datadir"

AUTOCODE_INTERVAL="${AUTOCODE_INTERVAL:-30}"

_green()  { printf '\033[0;32m%s\033[0m\n' "$*"; }
_red()    { printf '\033[0;31m%s\033[0m\n' "$*"; }
_yellow() { printf '\033[0;33m%s\033[0m\n' "$*"; }
_bold()   { printf '\033[1m%s\033[0m\n' "$*"; }

cmd_help() {
    _bold "autocode — multi-agent AI coding workflow"
    echo ""
    echo "USAGE"
    echo "  autocode <command> [args]"
    echo ""
    echo "COMMANDS"
    printf "  %-30s %s\n" 'plan "<requirement>"' 'Set requirements for the PLANNER (creates mail file)'
    printf "  %-30s %s\n" 'run [--once]'          'Run the full workflow loop (or a single tick with --once)'
    printf "  %-30s %s\n" 'retry [--once]'        'Resume workflow from current state (kills stale sessions, retries)'
    printf "  %-30s %s\n" 'status'                 'Show workflow state, metadata, and active sessions'
    printf "  %-30s %s\n" 'stop'                   'Kill all workflow sessions and clean up state files'
    printf "  %-30s %s\n" 'help'                   'Show this help message'
    echo ""
    echo "QUICKSTART"
    echo "  cd /path/to/your/repo"
    echo "  autocode plan \"Add user authentication with OAuth\""
    echo "  autocode run"
    echo ""
    echo "RETRY (resume after failure)"
    echo "  autocode retry              # resume from current state and run loop"
    echo "  autocode retry --once       # resume and run a single tick"
    echo ""
    echo "OPTIONS"
    printf "  %-30s %s\n" 'AUTOCODE_INTERVAL=<seconds>' "Polling interval for 'run' (default: $AUTOCODE_INTERVAL)"
    printf "  %-30s %s\n" 'AUTOCODE_CMD_PLANNER=<cmd>'  "Claude command for PLANNER role (default: $AUTOCODE_CMD_PLANNER)"
    printf "  %-30s %s\n" 'AUTOCODE_CMD_EXECUTOR=<cmd>' "Claude command for EXECUTOR role (default: $AUTOCODE_CMD_EXECUTOR)"
    printf "  %-30s %s\n" 'AUTOCODE_CMD_REVIEWER=<cmd>' "Claude command for REVIEWER role (default: $AUTOCODE_CMD_REVIEWER)"
    printf "  %-30s %s\n" 'AUTOCODE_CMD_JANITOR=<cmd>'  "Commit command for JANITOR role (default: $AUTOCODE_CMD_JANITOR)"
    printf "  %-30s %s\n" 'AUTOCODE_CMD_GIT=<cmd>'      "Git command for JANITOR push (default: $AUTOCODE_CMD_GIT)"
    echo ""
    echo "  Persistent config: ~/.claude-auto-code/config (created by 'make configure')"
    echo ""
    echo "INSTALLATION"
    echo "  make install          # create symlink in ~/.local/bin"
    echo "  make check            # verify all dependencies"
    echo "  make configure        # set up required directories and commands"
}

cmd_plan() {
    local requirement="${1:-}"
    local base_name
    base_name=$(get_base_name "$(pwd)")
    local mail_file="$datadir/${base_name}.PLANNER.mail"

    if [ -z "$requirement" ]; then
        _red "Error: requirement text is required"
        echo "Usage: autocode plan \"<requirement text>\""
        exit 1
    fi

    echo "$requirement" > "$mail_file"
    _green "Requirement written to $mail_file"
    echo "Run 'autocode run' to start the workflow."
}

_is_workflow_done() {
    local current_state
    current_state=$(read_state)
    if [ -n "$current_state" ]; then
        return 1
    fi
    local base_name
    base_name=$(get_base_name "$(pwd)")
    for role in PLANNER EXECUTOR REVIEWER JANITOR; do
        if tmux has-session -t "${base_name}-${role}" 2>/dev/null; then
            return 1
        fi
    done
    return 0
}

_tick() {
    "$SCRIPTS_DIR/cc-planner-session.sh"
    "$SCRIPTS_DIR/cc-executor-session.sh"
    "$SCRIPTS_DIR/cc-reviewer-session.sh"
    "$SCRIPTS_DIR/cc-janitor-session.sh"
}

cmd_run() {
    local once=false
    if [ "${1:-}" = "--once" ]; then
        once=true
    fi

    local base_name
    base_name=$(get_base_name "$(pwd)")
    local planner_mail="$datadir/${base_name}.PLANNER.mail"
    local current_state
    current_state=$(read_state)

    if ! $once; then
        if [ -z "$current_state" ] && [ ! -f "$planner_mail" ]; then
            _yellow "No requirement set. The PLANNER will auto-select a feature."
            echo "Tip: run 'autocode plan \"<requirement>\"' first to set a specific goal."
        fi
        echo "Starting workflow loop (interval: ${AUTOCODE_INTERVAL}s). Press Ctrl+C to stop."
        echo ""
    fi

    _tick

    if $once; then
        return 0
    fi

    while true; do
        sleep "$AUTOCODE_INTERVAL"
        echo "--- tick $(date '+%H:%M:%S') ---"
        _tick

        if _is_workflow_done; then
            echo ""
            _green "Workflow complete! All sessions finished and state cleaned up."
            break
        fi
    done
}

cmd_retry() {
    local once=false
    if [ "${1:-}" = "--once" ]; then
        once=true
    fi

    local base_name
    base_name=$(get_base_name "$(pwd)")
    local current_state
    current_state=$(read_state)

    if [ -z "$current_state" ]; then
        _red "No workflow state found. Nothing to retry."
        _yellow "Use 'autocode plan' and 'autocode run' to start a new workflow."
        exit 1
    fi

    _yellow "Current state: $current_state"

    case "$current_state" in
        planner:active)
            local sn="${base_name}-PLANNER"
            tmux has-session -t "$sn" 2>/dev/null && tmux kill-session -t "$sn"
            local req
            req=$(read_meta "requirements")
            if [ -n "$req" ]; then
                echo "$req" > "$datadir/${base_name}.PLANNER.mail"
            fi
            clear_state
            ;;
        planner:done)
            ;;
        executor:active)
            local sn="${base_name}-EXECUTOR"
            tmux has-session -t "$sn" 2>/dev/null && tmux kill-session -t "$sn"
            local gaps
            gaps=$(read_meta "gaps_path")
            if [ -n "$gaps" ]; then
                write_state "reviewer:gaps"
            else
                write_state "planner:done"
            fi
            ;;
        executor:done)
            ;;
        reviewer:active)
            local sn="${base_name}-REVIEWER"
            tmux has-session -t "$sn" 2>/dev/null && tmux kill-session -t "$sn"
            write_state "executor:done"
            ;;
        reviewer:approved)
            ;;
        reviewer:gaps)
            ;;
        janitor:commit|janitor:push)
            local sn="${base_name}-JANITOR"
            tmux has-session -t "$sn" 2>/dev/null && tmux kill-session -t "$sn"
            write_state "reviewer:approved"
            ;;
        *)
            _red "Unknown state: $current_state"
            exit 1
            ;;
    esac

    _green "Retry conditions restored. Starting workflow..."
    if $once; then
        _tick
    else
        cmd_run
    fi
}

cmd_status() {
    local base_name
    base_name=$(get_base_name "$(pwd)")

    echo "Repo:     $(pwd)"
    echo "Base:     $base_name"
    echo ""

    _bold "Role commands:"
    printf "  %-10s %s\n" "PLANNER"  "$AUTOCODE_CMD_PLANNER"
    printf "  %-10s %s\n" "EXECUTOR" "$AUTOCODE_CMD_EXECUTOR"
    printf "  %-10s %s\n" "REVIEWER" "$AUTOCODE_CMD_REVIEWER"
    printf "  %-10s %s\n" "JANITOR"  "$AUTOCODE_CMD_JANITOR"
    printf "  %-10s %s\n" "GIT"      "$AUTOCODE_CMD_GIT"
    echo ""

    _bold "Workflow state:"
    local current_state
    current_state=$(read_state)
    if [ -n "$current_state" ]; then
        _green "  State: $current_state"
        local updated_at
        updated_at=$(read_meta "updated_at")
        [ -n "$updated_at" ] && echo "  Updated: $updated_at"
        local plan
        plan=$(read_meta "plan_path")
        [ -n "$plan" ] && echo "  Plan: $plan"
        local gaps
        gaps=$(read_meta "gaps_path")
        [ -n "$gaps" ] && echo "  Gaps: $gaps"
        local req
        req=$(read_meta "requirements")
        [ -n "$req" ] && echo "  Requirements: $req"
        local iter
        iter=$(read_meta "review_iteration")
        [ -n "$iter" ] && echo "  Review iteration: $iter"
    else
        echo "  (idle — no active workflow)"
    fi
    echo ""

    _bold "Tmux sessions:"
    local found_session=false
    for role in PLANNER EXECUTOR REVIEWER JANITOR; do
        local session="${base_name}-${role}"
        if tmux has-session -t "$session" 2>/dev/null; then
            _green "  [running] $session"
            found_session=true
        fi
    done
    if ! $found_session; then
        echo "  (none)"
    fi
}

cmd_stop() {
    local base_name
    base_name=$(get_base_name "$(pwd)")

    echo "Stopping all workflow sessions for: $base_name"
    local stopped=0
    for role in PLANNER EXECUTOR REVIEWER JANITOR; do
        local session="${base_name}-${role}"
        if tmux has-session -t "$session" 2>/dev/null; then
            tmux kill-session -t "$session"
            _red "  Killed: $session"
            stopped=$((stopped + 1))
        fi
    done

    if [ "$stopped" -eq 0 ]; then
        echo "  No active sessions found."
    fi

    echo ""
    echo "Cleaning up state files..."
    local cleaned=0
    if [ -d "$datadir/${base_name}.lockdir" ]; then
        rm -rf "$datadir/${base_name}.lockdir"
        echo "  Removed: ${base_name}.lockdir"
        cleaned=$((cleaned + 1))
    fi
    for f in "$datadir/${base_name}".lock "$datadir/${base_name}".state "$datadir/${base_name}".meta "$datadir/${base_name}".PLANNER.mail; do
        if [ -f "$f" ]; then
            rm -f "$f"
            echo "  Removed: $(basename "$f")"
            cleaned=$((cleaned + 1))
        fi
    done
    for f in "$datadir/${base_name}"*.mail "$datadir/${base_name}"*.plan; do
        if [ -f "$f" ]; then
            rm -f "$f"
            echo "  Removed: $(basename "$f")"
            cleaned=$((cleaned + 1))
        fi
    done
    if [ "$cleaned" -eq 0 ]; then
        echo "  No files to clean."
    fi
}

COMMAND="${1:-help}"
shift || true

case "$COMMAND" in
    plan)     cmd_plan "$@" ;;
    run)      cmd_run "$@" ;;
    retry)    cmd_retry "$@" ;;
    status)   cmd_status ;;
    stop)     cmd_stop ;;
    help|--help|-h) cmd_help ;;
    *)
        _red "Unknown command: $COMMAND"
        echo ""
        cmd_help
        exit 1
        ;;
esac
